# Copy this file to .env.production and fill in real values before deploying.
# Never commit .env.production to git.

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mern-quantum?retryWrites=true&w=majority
PORT=3001
JWT_SECRET=<min-64-char-random-string>
JWT_REFRESH_SECRET=<different-min-64-char-random-string>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
NODE_ENV=production
CORS_ORIGIN=https://<your-frontend-domain>
QUANTUM_SEMANTICS_MODE=v2
SENTRY_DSN_BACKEND=
