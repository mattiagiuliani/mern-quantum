# Base URL of the backend (without /api/v1 — the code appends it automatically).
# Used in local npm-run-dev workflows.
# Copy this file to .env.local and fill in your values.

VITE_API_URL_DEV=http://localhost:3001
VITE_API_URL_PROD=https://mern-quantum.onrender.com

# Sentry (optional — leave blank to disable)
VITE_SENTRY_DSN_FRONTEND=
